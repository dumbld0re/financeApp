# Copy to .env.local for local testing with: npx vercel dev
#
# On Vercel you need ALL of these (then Redeploy):
#   SYNC_SECRET          — server (api/data.js)
#   VITE_SYNC_SECRET     — same value (baked into the app at BUILD time)
#   UPSTASH_REDIS_*      — auto-added when you connect Upstash Redis integration
#
# Common mistake: only setting SYNC_SECRET without VITE_SYNC_SECRET, or
# adding env vars without redeploying (Vite embeds VITE_* at build time).

VITE_SYNC_SECRET=your-long-random-secret
