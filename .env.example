# Copy to .env.local for local testing with: npx vercel dev
#
# On Vercel you need BOTH of these (then Redeploy):
#   SYNC_SECRET          — server (api/data.js); enter the same value in the
#                          app via the sync button in the header (it is stored
#                          in the browser, never baked into the bundle)
#   UPSTASH_REDIS_*      — auto-added when you connect Upstash Redis integration
#
# Note: VITE_SYNC_SECRET is no longer used — remove it from Vercel if it is
# still set, since build-time VITE_* values are readable in the public bundle.

SYNC_SECRET=your-long-random-secret
